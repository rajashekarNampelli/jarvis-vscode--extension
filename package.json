{
  "name": "jarvis-vscode-extension",
  "displayName": "Jarvis",
  "description": "AI chat panel powered by jarvis-model-router — model selection and streamed responses without any API key.",
  "version": "0.0.1",
  "publisher": "raja",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/raja/jarvis-vscode-extension"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI"
  ],
  "keywords": [
    "jarvis",
    "ollama",
    "llm",
    "chat"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onView:jarvis.chatView"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jarvis",
          "title": "Jarvis",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "jarvis": [
        {
          "type": "webview",
          "id": "jarvis.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "jarvis.refreshModels",
        "title": "Jarvis: Refresh Models"
      },
      {
        "command": "jarvis.clearChat",
        "title": "Jarvis: Clear Chat"
      }
    ],
    "configuration": {
      "title": "Jarvis",
      "properties": {
        "jarvis.baseUrl": {
          "type": "string",
          "default": "https://api.jarvis-ai-local-modelcloudflare.uk",
          "description": "Base URL of the jarvis-model-router service."
        }
      }
    }
  },
  "scripts": {
    "build": "npm run build:webview && npm run build:ext",
    "build:ext": "node esbuild.config.mjs",
    "build:webview": "vite build",
    "watch:ext": "node esbuild.config.mjs --watch",
    "watch:webview": "vite build --watch",
    "lint": "eslint src webview --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.ts\" \"webview/**/*.{ts,tsx,css}\"",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vscode/vsce": "^2.26.0",
    "autoprefixer": "^10.4.0",
    "esbuild": "^0.21.0",
    "eslint": "^8.57.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0"
  },
  "dependencies": {
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  }
}
